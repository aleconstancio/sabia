# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spaceeye
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Redis ──
REDIS_URL=redis://:changeme@localhost:6379/0

# ── Celery ──
CELERY_BROKER_URL=redis://:changeme@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:changeme@localhost:6379/0

# ── INPE (required for satellite data) ──
EMAIL_INPE=your-email@example.com

# ── Backend ──
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
TEMP_DIR=/tmp/spaceeye

# ── Authentication (optional) ──
# Set API_KEY to enable API key authentication on protected endpoints.
# Leave empty or unset to disable auth (default for development).
# API_KEY=your-secret-key-here
