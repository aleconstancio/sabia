FROM node:22-alpine AS builder
WORKDIR /app/apps/spaceeye-web
COPY apps/spaceeye-web/package.json apps/spaceeye-web/package-lock.json* ./
RUN npm ci
COPY apps/spaceeye-web/ .
ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/apps/spaceeye-web/build /usr/share/nginx/html
COPY apps/spaceeye-web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
