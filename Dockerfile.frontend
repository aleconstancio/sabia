FROM node:22-alpine AS builder
WORKDIR /app
COPY apps/spaceeye-web/package.json apps/spaceeye-web/package-lock.json* ./
RUN npm ci
COPY apps/spaceeye-web/ .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY apps/spaceeye-web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
